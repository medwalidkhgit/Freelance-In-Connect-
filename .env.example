# Local Docker Compose configuration example.
# Copy this file to .env and replace every "change-me" value with your local secret.
# Never commit a real .env file.

# Frontend
FRONTEND_PORT=5175
VITE_API_BASE_URL=http://localhost:8280
VITE_WS_BASE_URL=http://localhost:8280
VITE_MESSAGING_WS_ENDPOINT=/api/messaging/v1/ws
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_change_me

# Databases
POSTGRES_PASSWORD=fifa2014
POSTGRES_KEYCLOAK_PASSWORD=keycloak_secret
APPLICATION_DB_PASSWORD=fifa2014
PAYMENT_DB_PASSWORD=fifa2014
MESSAGING_DB_PASSWORD=messaging_secret

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=admin123
AUTH_SERVICE_CLIENT_SECRET=change-me
B2B_APP_CLIENT_SECRET=change-me

# Internal service authentication
INTERNAL_SERVICE_TOKEN=change-me

# OTP / SMTP
SMTP_ENABLED=false
APP_DEV_OTP_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@fic.local
SMTP_AUTH=false
SMTP_STARTTLS=false
OTP_TTL_MINUTES=10

# Stripe test mode
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_FEE_PERCENT=10
STRIPE_DEFAULT_CURRENCY=mad
STRIPE_ACCOUNT_LINK_REFRESH_URL=http://localhost:5175/freelancer
STRIPE_ACCOUNT_LINK_RETURN_URL=http://localhost:5175/freelancer

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=change-me
AZURE_STORAGE_PROFILE_PICTURES_CONTAINER=profile-pictures
AZURE_STORAGE_COMPANY_LOGOS_CONTAINER=company-logos
AZURE_STORAGE_CVS_CONTAINER=cvs
